      "item": [
        {
          "id": "7fbab67b-b69b-40d9-9ccf-6a9c980ff872",
          "name": "Post a Payment",
          "request": {
            "name": "Post a Payment",
            "description": {
              "content": "Single global entry point for the Beep payouts platform. The `function`\nfield discriminates the operation: `BEEP.postPayment`, `BEEP.queryPayment`,\n`BEEP.validateAccount`, `BEEP.getBill`, `BEEP.getBalance`, `BEEP.refundPayment`.\nUsed for mobile money B2C, bulk disbursement, bank transfers, airtime/data\nvending, and bill payments (DSTV, GOTV, electricity, water).\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "v1",
                "global-api",
                "payments"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"function\": \"<string>\",\n  \"countryCode\": \"<string>\",\n  \"payload\": {\n    \"credentials\": {\n      \"username\": \"<string>\",\n      \"password\": \"<string>\"\n    },\n    \"packet\": {\n      \"serviceCode\": \"<string>\",\n      \"MSISDN\": \"<string>\",\n      \"accountNumber\": \"<string>\",\n      \"payerTransactionID\": \"<string>\",\n      \"amount\": \"<double>\",\n      \"datePaymentReceived\": \"<string>\",\n      \"currencyCode\": \"<string>\",\n      \"countryCode\": \"<string>\",\n      \"narration\": \"<string>\",\n      \"invoiceNumber\": \"<string>\",\n      \"hubID\": \"<string>\",\n      \"paymentMode\": \"<string>\",\n      \"customerNames\": \"<string>\",\n      \"extraData\": {\n        \"callbackUrl\": \"<uri>\",\n        \"pushToOriginator\": \"<boolean>\",\n        \"destinationBankCode\": \"<string>\",\n        \"destinationBankName\": \"<string>\",\n        \"destinationAccountName\": \"<string>\",\n        \"destinationAccountNo\": \"<string>\"\n      }\n    }\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [
            {
              "id": "614d4636-9c5b-41a9-be25-5897b7e77821",
              "name": "Payout accepted (asynchronous — status callbacks fire on the configured callback URL when payment is delivered)",
              "originalRequest": {
                "url": {
                  "path": [
                    "v1",
                    "global-api",
                    "payments"
                  ],
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "query": [],
                  "variable": []
                },
                "header": [
                  {
                    "description": {
                      "content": "Added as a part of security scheme: basic",
                      "type": "text/plain"
                    },
                    "key": "Authorization",
                    "value": "Basic <credentials>"
                  },
                  {
                    "key": "Accept",
                    "value": "application/json"
                  }
                ],
                "method": "POST",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"function\": \"BEEP.postPayment\",\n  \"countryCode\": \"KE\",\n  \"payload\": {\n    \"credentials\": {\n      \"username\": \"sandboxuser\",\n      \"password\": \"sandboxpassword!\"\n    },\n    \"packet\": {\n      \"serviceCode\": \"MPESA-B2C\",\n      \"MSISDN\": \"254712345678\",\n      \"accountNumber\": \"254712345678\",\n      \"payerTransactionID\": \"TXN-2026-05-24-0001\",\n      \"amount\": 2500,\n      \"datePaymentReceived\": \"2026-05-24 10:15:00\",\n      \"currencyCode\": \"KE\",\n      \"countryCode\": \"KE\",\n      \"narration\": \"Vendor payout — May invoice\",\n      \"paymentMode\": \"Mobile\",\n      \"customerNames\": \"Wanjiru Mwangi\",\n      \"extraData\": {\n        \"callbackUrl\": \"https://merchant.example.co.ke/tingg/payout-callback\",\n        \"pushToOriginator\": true\n      }\n    }\n  }\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                }
              },
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"authStatus\": {\n    \"authStatusCode\": 131,\n    \"authStatusDescription\": \"Authentication was successful\"\n  },\n  \"results\": [\n    {\n      \"statusCode\": 139,\n      \"statusDescription\": \"Payment pending acknowledgement\",\n      \"payerTransactionID\": \"TXN-2026-05-24-0001\",\n      \"beepTransactionID\": 9876543210\n    }\n  ]\n}",
              "cookie": [],
