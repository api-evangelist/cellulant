                ],
                "method": "POST",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"notificationType\": \"OTP\",\n  \"channels\": [\n    \"SMS\"\n  ],\n  \"referenceID\": \"ref-cas-123\",\n  \"callbackUrl\": \"https://merchant.example.co.ke/sms/callback\",\n  \"smsDto\": {\n    \"msisdn\": [\n      \"254712345678\"\n    ],\n    \"message\": \"Your Tingg OTP is ${code}. Valid for 5 minutes.\",\n    \"params\": {\n      \"code\": \"648291\"\n    },\n    \"senderID\": \"TINGG\"\n  }\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
