          "name": "Send Engagement Message",
          "request": {
            "name": "Send Engagement Message",
            "description": {
              "content": "Queue an SMS notification (OTP, transactional, or standard). Delivery status is reported via callback to the supplied callbackUrl.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "api",
                "v2",
                "engagement"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notificationType\": \"<string>\",\n  \"channels\": [\n    \"<string>\",\n    \"<string>\"\n  ],\n  \"referenceID\": \"<string>\",\n  \"smsDto\": {\n    \"msisdn\": [\n      \"<string>\",\n      \"<string>\"\n    ],\n    \"message\": \"<string>\",\n    \"params\": {\n      \"key_0\": \"<string>\",\n      \"key_1\": \"<string>\"\n    },\n    \"senderID\": \"<string>\"\n  },\n  \"callbackUrl\": \"<uri>\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [
            {
              "id": "95c89599-c861-4527-ab44-7db4a4fd63b9",
              "name": "Message queued",
